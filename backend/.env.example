# Server Configuration
PORT=8080
GIN_MODE=debug

# Database Configuration
DB_DSN=root:@tcp(localhost:3306)/bw_ai_check?charset=utf8mb4&parseTime=True&loc=Local

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# Logger Configuration
LOG_LEVEL=info
LOG_DIR=logs
LOG_RETENTION_DAYS=7
LOG_COMPRESS=true

# Storage Configuration (MinIO)
STORAGE_DRIVER=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=bw-ai-check
STORAGE_USE_SSL=false
# 文件公开访问基础地址（留空则自动推断为 http(s)://STORAGE_ENDPOINT）
STORAGE_PUBLIC_URL=
# 单文件最大上传大小（MB），0 表示不限制
STORAGE_MAX_SIZE_MB=50

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
