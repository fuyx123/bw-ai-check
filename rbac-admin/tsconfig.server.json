{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "server-dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "react"]
  },
  "include": [
    "server/**/*.ts",
    "src/mocks/data/**/*.ts",
    "src/types/rbac.ts"
  ]
}
